# Solenne env vars. Copy to .env (local) or set in Vercel project (prod).
# Keep all secret values out of git. Only this template is committed.

# ===== Frontend (build-time, Vite) =====

# Dev: http://localhost:3000 if running serverless via `vercel dev`. Prod: empty (relative /api/*).
VITE_API_URL=

# Stripe publishable key for the Solenne account.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx

# Product display defaults (StripeCheckoutModal reads these).
VITE_PRODUCT_NAME=Solenne PDRN Pink Peptide Serum
VITE_PRODUCT_PRICE=189000
VITE_PRODUCT_CURRENCY=PYG

# Meta Pixel ID (Solenne). The pixel snippet in index.html is hostname-guarded
# to bysolenne.shop so this is only used by client tracking helpers.
VITE_META_PIXEL_ID=2322991584857999

# n8n webhook for Solenne order completions (consumed by orderService fallback).
VITE_N8N_WEBHOOK_URL=https://n8n.thebrightidea.ai/webhook/solenneorder

# WhatsApp closer number (Sofia). Used by exit-intent and post-purchase deeplinks.
VITE_WHATSAPP_NUMBER=595976287180

# ===== Backend (runtime, Vercel serverless) =====

# Stripe secret key (Solenne account). Live key only in Vercel prod.
STRIPE_SECRET_KEY=sk_live_or_test_xxx

# Stripe webhook signing secret. Set after creating the webhook endpoint at
# https://bysolenne.shop/api/stripe-webhook. Required, no fallback.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# n8n webhook URLs (server-side; the runtime forwards orders here).
N8N_WEBHOOK_URL=https://n8n.thebrightidea.ai/webhook/solenneorder
N8N_ABANDONED_CHECKOUT_WEBHOOK_URL=https://n8n.thebrightidea.ai/webhook/solenne-abandoned

# Ordefy fulfillment. Get the per-store webhook URL + API key from Ordefy admin.
ORDEFY_WEBHOOK_URL=https://api.ordefy.io/api/webhook/orders/<solenne-store-id>
ORDEFY_API_KEY=wh_xxx

# Meta Conversions API (server-side dedup with browser pixel).
META_CAPI_ACCESS_TOKEN=EAA_xxx
META_PIXEL_ID=2322991584857999

# Optional: Google Maps key for address geocoding (can reuse cross-brand).
GOOGLE_MAPS_API_KEY=
